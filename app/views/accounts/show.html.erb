<%= turbo_stream_from @user %>

<!-- Hero Section -->
<section class="relative h-[20vh] md:h-[30vh] sm:h-[25vh] bg-center bg-cover flex flex-col justify-center items-center text-white text-center px-4" style="background-image: url('<%= asset_path('hero.jpeg') %>');">
  <div class="absolute inset-0 bg-black opacity-50"></div>
  <div class="relative z-10">
    <h1 class="text-4xl font-extrabold">Manage Account</h1>
  </div>
  <div class="absolute top-4 left-4 text-2xl font-extrabold z-10">Rent A Clue!</div>
</section>

<!-- Fine to Pay Card -->
<% if @fine.present? %>
  <div class="bg-red-600 text-white rounded-xl shadow-md p-6 mb-6 flex flex-col md:flex-row justify-between items-start md:items-center">
    <div>
      <h2 class="text-lg font-semibold mb-2">Fine to pay</h2>
      <p><span class="font-medium">Fine:</span> £<%= @fine.amount %></p>
      <p><span class="font-medium">Reason:</span> <%= @fine.reason %></p>
      <p><span class="font-medium">Status:</span> <%= @fine.status.titleize %></p>
    </div>
    <%= button_to "Pay", pay_fine_path(@fine), method: :post,
        class: "mt-4 md:mt-0 bg-green-200 hover:bg-green-300 text-green-800 font-semibold px-5 py-2 rounded-full shadow transition" %>
  </div>
<% end %>

<!-- Dashboard Content -->
<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <!-- Current Rental -->
    <div class="bg-white rounded-xl shadow p-6 md:col-span-2 mb-6">
      <div class="flex">
        <h2 class="text-lg font-semibold mb-4 flex-grow">Current Rental</h2>
        <span class="h-[1.7rem] flex-shrink px-3 py-1 text-xs bg-teal-100 text-teal-600 rounded-full font-medium">To Be Sent</span>
      </div>
      <div class="flex flex-col md:flex-row gap-4 items-start">
        <%= image_tag 'trials-of-camelot.jpg', alt: 'Puzzle', class: 'w-32 h-32 object-contain' %>
        <div class="text-sm text-gray-700 space-y-1">
          <p><span class="font-semibold text-teal-600">Puzzle:</span> Trials of Camelot</p>
          <p>Return by date: <%= Date.parse("2025-03-05").strftime("%Y-%m-%d") %></p>
          <p>Tracking Link: <a href="#" class="underline">Click here</a></p>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <!-- Subscription Status -->
      <div class="bg-white rounded-xl shadow p-6">
        <div class="flex">
          <h2 class="text-lg font-semibold mb-4 flex-grow">Subscription</h2>

          <span class="h-[1.7rem] flex-shrink px-3 py-1 text-xs bg-teal-100 text-teal-600 rounded-full font-medium">Active</span>
        </div>
        <p class="text-sm text-gray-700"><span class="font-semibold text-teal-600">Plan:</span> Monthly</p>
        <p class="text-sm text-gray-700 mt-1">Next Billing date: 2025-03-05</p>
      </div>

    <!-- Shipping Details -->
    <div class="bg-white rounded-xl shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold">Shipping Details</h2>
        <%= link_to "Edit", "", class: "text-sm text-teal-600 hover:underline" %>
      </div>
      <% if @contact %>
        <%= render @contact %>
      <% else %>
        <%= link_to "Add shipping details", new_contact_path, class: 'mx-auto px-6 py-2 bg-green-600 hover:bg-green-900 text-white' %>
        <% end %>
      </div>
    </div>
  </div>
</div>



